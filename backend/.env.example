# EvacuWay backend environment template. Copy to .env and adjust as needed.
# NEVER commit a real .env — it is gitignored.

# --- Paths (defaults resolve to the repo's data/ directory) ---
DATA_CSV_PATH=data/metro_manila_flood_dataset.csv
DATA_XLSX_PATH=data/Evacuation_Marikina_Dataset.xlsx
GRAPH_CACHE_PATH=data/metro_manila_graph.graphml
RESULTS_DIR=data/results

# --- Simulation parameters ---
SIMULATION_MAX_TICKS=500
AGENT_SPEED_KMH=40
MAX_AGENTS_PER_ZONE=500
EVAC_WINDOW_MIN=360
ORIGIN_DISCHARGE_PER_MIN=12

# --- CORS (frontend origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# --- OPTIONAL external API keys (leave blank if unused; never hardcode) ---
# PAGASA_API_KEY=
# OPENTOPOGRAPHY_API_KEY=
