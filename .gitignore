# --- Simulation outputs (large per-run files; aggregates are kept) ---
data/results/*
!data/results/.gitkeep
!data/results/summary.json
!data/results/statistics.json

# --- OSMnx cache (regenerate via scripts/extract_osmnx_graph.py) ---
data/metro_manila_graph.graphml
data/nodes.csv
data/edges.csv

# --- Raw Overpass dump (large; recompile artifact via scripts/build_road_network.mjs) ---
# The compiled data/marikina_road_network.json IS committed (needed at runtime).
data/osm_cache/

# --- Android ---
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
*.iml

