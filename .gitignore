# --- Secrets ---
.env
.env.local
*.env.local
backend/.env
frontend/.env

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
backend/venv/
.pytest_cache/
.ipynb_checkpoints/

# --- Node / frontend ---
node_modules/
frontend/dist/
frontend/node_modules/
